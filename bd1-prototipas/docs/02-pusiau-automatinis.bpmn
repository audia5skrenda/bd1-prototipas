<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_02" targetNamespace="http://planiniai.local/bpmn">
  <bpmn:process id="Process_02" name="Pusiau automatinis tvarkymas" isExecutable="false">
    <bpmn:startEvent id="Start" name="Nepilnas email"><bpmn:outgoing>F1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:userTask id="Open" name="Atidaryti email"><bpmn:incoming>F1</bpmn:incoming><bpmn:outgoing>F2</bpmn:outgoing></bpmn:userTask>
    <bpmn:userTask id="Edit" name="Redaguoti laukus"><bpmn:incoming>F2</bpmn:incoming><bpmn:incoming>FBack</bpmn:incoming><bpmn:outgoing>F3</bpmn:outgoing></bpmn:userTask>
    <bpmn:exclusiveGateway id="Valid" name="Užpildyta?"><bpmn:incoming>F3</bpmn:incoming><bpmn:outgoing>F4</bpmn:outgoing><bpmn:outgoing>FBack</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:userTask id="Confirm" name="Patvirtinti"><bpmn:incoming>F4</bpmn:incoming><bpmn:outgoing>F5</bpmn:outgoing></bpmn:userTask>
    <bpmn:serviceTask id="Save" name="Išsaugoti pataisymus"><bpmn:incoming>F5</bpmn:incoming><bpmn:outgoing>F6</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="Create" name="Sukurti darbą"><bpmn:incoming>F6</bpmn:incoming><bpmn:outgoing>F7</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="Send" name="Siųsti pranešimus"><bpmn:incoming>F7</bpmn:incoming><bpmn:outgoing>F8</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:endEvent id="End" name="Sutvarkyta"><bpmn:incoming>F8</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="F1" sourceRef="Start" targetRef="Open"/>
    <bpmn:sequenceFlow id="F2" sourceRef="Open" targetRef="Edit"/>
    <bpmn:sequenceFlow id="F3" sourceRef="Edit" targetRef="Valid"/>
    <bpmn:sequenceFlow id="F4" name="Taip" sourceRef="Valid" targetRef="Confirm"/>
    <bpmn:sequenceFlow id="FBack" name="Ne" sourceRef="Valid" targetRef="Edit"/>
    <bpmn:sequenceFlow id="F5" sourceRef="Confirm" targetRef="Save"/>
    <bpmn:sequenceFlow id="F6" sourceRef="Save" targetRef="Create"/>
    <bpmn:sequenceFlow id="F7" sourceRef="Create" targetRef="Send"/>
    <bpmn:sequenceFlow id="F8" sourceRef="Send" targetRef="End"/>
  </bpmn:process>
