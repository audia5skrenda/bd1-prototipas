<?xml version="1.0" encoding="UTF-8"?>
<bpmn:definitions xmlns:bpmn="http://www.omg.org/spec/BPMN/20100524/MODEL" xmlns:bpmndi="http://www.omg.org/spec/BPMN/20100524/DI" xmlns:dc="http://www.omg.org/spec/DD/20100524/DC" xmlns:di="http://www.omg.org/spec/DD/20100524/DI" id="Definitions_03" targetNamespace="http://planiniai.local/bpmn">
  <bpmn:process id="Process_03" name="Email atmetimas" isExecutable="false">
    <bpmn:startEvent id="Start" name="Email sąraše"><bpmn:outgoing>F1</bpmn:outgoing></bpmn:startEvent>
    <bpmn:userTask id="Review" name="Peržiūrėti email"><bpmn:incoming>F1</bpmn:incoming><bpmn:outgoing>F2</bpmn:outgoing></bpmn:userTask>
    <bpmn:exclusiveGateway id="Useful" name="Reikalingas?"><bpmn:incoming>F2</bpmn:incoming><bpmn:outgoing>FKeep</bpmn:outgoing><bpmn:outgoing>FReject</bpmn:outgoing></bpmn:exclusiveGateway>
    <bpmn:endEvent id="Keep" name="Palikti tvarkymui"><bpmn:incoming>FKeep</bpmn:incoming></bpmn:endEvent>
    <bpmn:userTask id="Reject" name="Spausti Atmesti"><bpmn:incoming>FReject</bpmn:incoming><bpmn:outgoing>F3</bpmn:outgoing></bpmn:userTask>
    <bpmn:serviceTask id="Save" name="Įrašyti į rejected_emails"><bpmn:incoming>F3</bpmn:incoming><bpmn:outgoing>F4</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:serviceTask id="Hide" name="Paslėpti iš sistemos"><bpmn:incoming>F4</bpmn:incoming><bpmn:outgoing>F5</bpmn:outgoing></bpmn:serviceTask>
    <bpmn:endEvent id="End" name="Email dingsta"><bpmn:incoming>F5</bpmn:incoming></bpmn:endEvent>
    <bpmn:sequenceFlow id="F1" sourceRef="Start" targetRef="Review"/>
    <bpmn:sequenceFlow id="F2" sourceRef="Review" targetRef="Useful"/>
    <bpmn:sequenceFlow id="FKeep" name="Taip" sourceRef="Useful" targetRef="Keep"/>
    <bpmn:sequenceFlow id="FReject" name="Ne" sourceRef="Useful" targetRef="Reject"/>
    <bpmn:sequenceFlow id="F3" sourceRef="Reject" targetRef="Save"/>
    <bpmn:sequenceFlow id="F4" sourceRef="Save" targetRef="Hide"/>
    <bpmn:sequenceFlow id="F5" sourceRef="Hide" targetRef="End"/>
  </bpmn:process>
  <bpmndi:BPMNDiagram id="Diagram_03"><bpmndi:BPMNPlane id="Plane_03" bpmnElement="Process_03">
    <bpmndi:BPMNShape id="S_Start" bpmnElement="Start"><dc:Bounds x="100" y="120" width="36" height="36"/></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="S_Review" bpmnElement="Review"><dc:Bounds x="190" y="98" width="130" height="80"/></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="S_Useful" bpmnElement="Useful" isMarkerVisible="true"><dc:Bounds x="380" y="113" width="50" height="50"/></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="S_Keep" bpmnElement="Keep"><dc:Bounds x="387" y="240" width="36" height="36"/></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="S_Reject" bpmnElement="Reject"><dc:Bounds x="490" y="98" width="120" height="80"/></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="S_Save" bpmnElement="Save"><dc:Bounds x="660" y="98" width="150" height="80"/></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="S_Hide" bpmnElement="Hide"><dc:Bounds x="860" y="98" width="140" height="80"/></bpmndi:BPMNShape>
    <bpmndi:BPMNShape id="S_End" bpmnElement="End"><dc:Bounds x="1050" y="120" width="36" height="36"/></bpmndi:BPMNShape>
    <bpmndi:BPMNEdge id="E_F1" bpmnElement="F1"><di:waypoint x="136" y="138"/><di:waypoint x="190" y="138"/></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="E_F2" bpmnElement="F2"><di:waypoint x="320" y="138"/><di:waypoint x="380" y="138"/></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="E_FKeep" bpmnElement="FKeep"><di:waypoint x="405" y="163"/><di:waypoint x="405" y="240"/></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="E_FReject" bpmnElement="FReject"><di:waypoint x="430" y="138"/><di:waypoint x="490" y="138"/></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="E_F3" bpmnElement="F3"><di:waypoint x="610" y="138"/><di:waypoint x="660" y="138"/></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="E_F4" bpmnElement="F4"><di:waypoint x="810" y="138"/><di:waypoint x="860" y="138"/></bpmndi:BPMNEdge>
    <bpmndi:BPMNEdge id="E_F5" bpmnElement="F5"><di:waypoint x="1000" y="138"/><di:waypoint x="1050" y="138"/></bpmndi:BPMNEdge>
  </bpmndi:BPMNPlane></bpmndi:BPMNDiagram>
</bpmn:definitions>
